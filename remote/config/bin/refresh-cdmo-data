#!/bin/bash -e

info() {
  echo "$(date) $@"
}

usage() {
  echo "usage: $(basename $0) [-d] (dev mode)"
  cat << EOF
usage: $(basename $0) options

Options:
-h : this help
-v : (optional) if given, dev mode
-d : (optional) if given, debug mode (compares doesn't write)
-t [T|W] : (opt) data type: T=tide/temp, W=wind. Default: both
-S <starttime> : (opt) start of timeline for upsert. YYYY-mm-ddTHH:MM in station tzone
-E <endtime> : (opt) end of timeline for upsert. YYYY-mm-ddTHH:MM in station tzone
EOF

}

fail() {
  [ -n "$1" ] && echo $1
  usage
  exit 1
}

devmode=0
station=welinwq
while getopts ":vdht:s:S:E:" opt; do
  case $opt in
    s ) station=$OPTARG;;
    S ) startstr="-S $OPTARG";;
    E ) endstr="-E $OPTARG";;
    t ) typestr="-t $OPTARG";;
    d ) debugstr='-d';;
    v ) devmode=1;;
    h ) usage; exit 0;;
    * ) fail;;
  esac
done
shift $(($OPTIND - 1))

# Sanity check so we don't run prod in dev
[ $(uname) == 'Darwin' ] && [ $devmode -eq 0 ] && fail "I don't think this is production"


: '
Run the cdmo_refresh job to pull and store the latest cdmo water and/or wind data or, if start & end 
params are provided, upsert the data defined by that timeline.
'

if [ "$devmode" -eq 1 ]; then
  export DJANGO_SETTINGS_MODULE=project.settings.dev
  compose_path=$WNTT/local/docker-compose-local.yml
else
  export DJANGO_SETTINGS_MODULE=project.settings.prod
  compose_path=$HOME/docker-compose.yml
fi

# Run the python script in a new, temporary api container
docker compose -f $compose_path run --rm api app/datasource/cdmo_refresh.py -s $station ${debugstr} ${typestr} ${startstr} ${endstr}

exit 0
