#!/bin/bash -e

info() {
  echo "$(date) $@"
}

usage() {
  echo "usage: $(basename $0) [-d] (dev mode)"
}

fail() {
  [ -n "$1" ] && echo $1
  usage
  exit 1
}

devmode=0
while getopts ":dh" opt; do
  case $opt in
    d ) devmode=1;;
    h ) usage; exit 0;;
    * ) fail;;
  esac
done
shift $(($OPTIND - 1))

# Sanity check so we don't run prod in dev
[ $(uname) == 'Darwin' ] && [ $devmode -eq 0 ] && fail "I don't think this is production"


: '
Run the cdmo_refresh job to pull the latest cdmo water and wind data and save it to our data store.
Data refreshes from CDMO sources to CDMO occur perhaps every 15 to 30 minutes.
This should be run often enough to not keep users waiting to see data that is available in CDMO, but
not so often as to be a resource hog.  Every 15 minutes is probably a good target.
'

if [ "$devmode" -eq 1 ]; then
  export DJANGO_SETTINGS_MODULE=project.settings.dev
  compose_path=$WNTT/local/docker-compose-local.yml
else
  export DJANGO_SETTINGS_MODULE=project.settings.prod
  compose_path=$HOME/docker-compose.yml
fi
docker compose -f $compose_path run --rm api app/datasource/cdmo_refresh.py -s welinwq

exit 0
