#!/bin/bash -e

info() {
  echo "$(date) $@"
}

cwd=$(pwd)
rootdir=$HOME/datamount/surge
workdir=$rootdir/tmp
archive=$rootdir/archive
datadir=$rootdir/data
mkdir -p $workdir $archive $datadir

# List of NOAA station ids to pull.  For example of UI for this data:
# See https://slosh.nws.noaa.gov/etsurge2.0/index.php?stid=8419317&datum=MLLW&show=0-0-1-1-0
# Edit this whenever a reserve is added/subtracted.
stations=("8419317" "8658163")

: '
Top level directories are named etss.<date>, e.g. etss.20251029, and the most recent few days files
are kept on the host. Each contains several varieties of tar files, with the time "cycle" (0, 6, 12 or 18) 
embedded in the name. The one we want is etss.t${cycle}z.csv.tar.gz.  NOAA publishes the files on this
schedule, in a 24-hour cycle, with all datetimes in UTC:
- ~00:15 UTC: cycle 18 of prior day. Use predictions for 01:00, 02:00, 03:00, 04:00, 05:00, 06:00
- ~06:15 UTC: cycle 00. Use predictions for 07:00, 08:00, 09:00, 10:00, 11:00, 12:00
- ~12:15 UTC: cycle 06. Use predictions for 13:00, 14:00, 15:00, 16:00, 17:00, 18:00
- ~18:15 UTC: cycle 12. Use predictions for 19:00, 20:00, 21:00, 22:00, 23:00, 00:00

Translating to Eastern Standard Time:
- ~01:15 EST: cycle 00. Use predictions for 02:00, 03:00, 04:00, 05:00, 06:00, 07:00
- ~07:15 EST: cycle 06. Use predictions for 08:00, 09:00, 10:00, 11:00, 12:00, 13:00
- ~13:15 EST: cycle 12. Use predictions for 14:00, 15:00, 16:00, 17:00, 18:00, 19:00
- ~19:15 EST: cycle 18. Use predictions for 20:00, 21:00, 22:00, 23:00, 00:00, 01:00
'

# Calculate the most recent cycle available to download. All datetimes are UTC.
filedate=$(date -u +%Y%m%d)
curtime=$(date -u +%H%M)
if [[ $curtime > "0629" ]] && [[ $curtime < "1230" ]]; then
    cycle='00'
elif [[ $curtime > "1229" ]] && [[ $curtime < "1830" ]]; then
    cycle='06'
elif [[ $curtime > "1829" ]]; then
    cycle='12'
elif [[ $curtime < "0030" ]]; then
    cycle='12'
    filedate=$(date -u -d '-1 day' +%Y%m%d)
else
    cycle='18'
    filedate=$(date -u -d '-1 day' +%Y%m%d)
fi

info "Pulling cycle $cycle for filedate $filedate"

# This is the expected most recent tar file.
target=etss.t${cycle}z.csv.tar.gz

cd $workdir
rm -rf *  # clean up files from previous run 
url="https://nomads.ncep.noaa.gov/pub/data/nccf/com/petss/prod/etss.${filedate}/${target}"
curl --no-progress-meter --fail-with-body -o $target $url || {
  info "Failed to download $url"
  exit 1
}
tar zxf $target || {
  info "Failed to extract $target"
  exit 1
}

# At this point we should have:
# etss.<date>/
#    t<cycle>z.csv/
#       <station>.csv ... for all stations

for ((i=0; i<${#stations[@]}; i++)); do
  datafile=etss.$filedate/t${cycle}z.csv/${stations[$i]}.csv
  if [ ! -f $datafile ]; then
    info "Expected file $datafile not found after extraction."
  else
    cp $datafile $datadir
    cp $datafile $archive/${stations[$i]}-${filedate}-${cycle}.csv
    info "extracted ${stations[$i]}.csv"
    # Run the surge_logger util in the api container
    DJANGO_SETTINGS_MODULE=project.settings.prod docker compose -f $HOME/docker-compose.yml run --rm \
      api app/surge_logger.py \
      -d $filedate -c $cycle -s ${stations[$i]} && info "logged ${stations[$i]}.csv"
  fi
done

# We'll leave the tmp dir contents around for debugging.
# rm -rf $workdir/*
echo "$filedate $cycle" >> $rootdir/log

exit 0
